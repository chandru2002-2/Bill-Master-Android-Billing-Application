<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bill_entry_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FD"
    tools:context=".BillEntry">

    <!-- Top Decorative Header -->
    <View
        android:id="@+id/top_accent_bg"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/header_gradient_bg"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Action Header -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_shop_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BILLING HUB"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textColor="#CCFFFFFF"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_bill_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checkout"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_view_history"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/glass_button_bg"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="@android:color/white"
            android:layout_marginEnd="12dp"/>

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/glass_button_bg"
            android:src="@android:drawable/ic_menu_preferences"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- Popular Items Card (Now Customizable) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/popular_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/header_container"
        app:layout_constraintBottom_toBottomOf="@id/top_accent_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Quick Add"
                    android:textStyle="bold"
                    android:textColor="#2D3748" />

                <!-- ✅ Added: Manage Button to add/edit quick items -->
                <ImageView
                    android:id="@+id/btn_manage_quick_add"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:layout_marginEnd="16dp"
                    app:tint="#3F51B5"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_manual_entry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Manual"
                    android:textStyle="bold"
                    android:textColor="#3F51B5"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Changed ScrollView height to wrap_content to support multiple lines of buttons -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="120dp"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/fl_product_buttons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flexWrap="wrap"
                    app:alignItems="stretch"
                    app:alignContent="stretch" />
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Main Bill List (The "Receipt" view) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_bill_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/popular_card"
        app:layout_constraintBottom_toTopOf="@id/bottom_checkout_card"
        tools:listitem="@layout/item_bill_entry" />

    <!-- Scan FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_scan_item"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@drawable/ic_scan"
        app:backgroundTint="#3F51B5"
        app:tint="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/bottom_checkout_card"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Floating Checkout Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_checkout_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Amount"
                    android:textColor="#718096"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_total_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 0.00"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#3F51B5" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_clear_bill_entry"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/rounded_outline_button"
                    android:src="@android:drawable/ic_delete"
                    app:tint="#E53E3E"
                    android:layout_marginEnd="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_next"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Checkout Now"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#3F51B5" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>